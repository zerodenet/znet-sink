{
  "name": "znetsink",
  "version": "0.0.6",
  "description": "ZNet Sink desktop client for ZeroDenet",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:nodes": "pnpm test:nodes-probe && pnpm test:nodes-view-model && pnpm test:nodes-select",
    "test:nodes-probe": "node scripts/test-nodes-probe-state.mjs && node scripts/test-nodes-probe-controller.mjs",
    "test:nodes-view-model": "node --experimental-strip-types --loader ./scripts/lib-alias-loader.mjs scripts/test-nodes-view-model.mjs",
    "test:nodes-select": "node scripts/test-nodes-select-args.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "prepare": "husky",
    "commit": "git-cz",
    "lint:commit": "commitlint --edit"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "author": "ZeroDenet <zerodenet.org>",
  "license": "MPL-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-updater": "^2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.0",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.14",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.8",
    "svelte-check": "^4.4.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  }
}
